rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /offline_bundles/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /{allPaths=**} {
      allow read, write: if false; // Default deny
    }
  }
}
